@misc{b8825c7645ae5bc6aad858671c50d4220306adcd,
  author = {Mohammed Farhan and Caroline C. Krejci and Megan M. Olsen and M. Raunak},
  title = {Metamorphic Testing for Hybrid Simulation Validation},
  journal = {2021 Annual Modeling and Simulation Conference (ANNSIM)},
  year = {2021},
  doi = {10.23919/ANNSIM52504.2021.9552058},
  pages = {1-12},
  abstract = {Proper validation of a simulation model is essential for confidence in its accuracy and credibility. However, many of the most effective approaches for simulation validation require access to data that may be unavailable. Metamorphic Testing (MT), an approach from traditional software testing, has been shown to be useful for verification of simulation software in similar situations. Recent research shows that MT can be applied to the validation of agent based and discrete event simulation models as well. In this paper we build on that work and show how MT can be applied to hybrid simulation models. We demonstrate the effectiveness of our approach by applying it on a case study of helping behavior among servers in a restaurant.}
}

@misc{950b0c3760738c500af69bca9b239e3c564d5816,
  author = {Bo Zhang and Chi Zhang and Xiangyu Hu},
  title = {A method for automated regression test in scientific computing libraries: illustration with SPHinXsys},
  journal = {Unknown Journal},
  year = {2023},
  abstract = {Scientific computing libraries, either being in-house or open-source, have experienced enormous progress in both engineering and scientific research. It is therefore essential to ensure that the modifications in the source code aroused by bug fixing or new feature development wouldn't compromise the accuracy and functionality that has already been validated and verified. With this in mind, this paper introduces a method for developing and implementing an automatic regression test environment and takes the open-source multi-physics library SPHinXsys \\cite\{zhang2021sphinxsys\} as an example. Firstly, the reference database for each benchmark test is generated from monitored data by multiple executions. This database contains the maximum variation range of metrics for different types of strategies, i.e., time-averaged method, ensemble-averaged method as well as the dynamic time warping method, covering the uncertainty arising from parallel computing, particle relaxation, physical instabilities, etc. Then, new results obtained after source code modification will be tested with them according to a curve-similarity based comparison. Whenever the source code is updated, the regression test will be carried out automatically for all test cases and used to report the validity of the current results. This regression test environment has already been implemented in all dynamics test cases released in SPHinXsys, including fluid dynamics, solid mechanics, fluid-structure interaction, thermal and mass diffusion, reaction-diffusion, and their multi-physics coupling, and shows good capability for testing various problems. It's worth noting that while the present test environment is built and implemented for a specific scientific computing library, its underlying principle is generic and can be applied to many others.}
}

@misc{5ea70f3bbe6a709ef9fbdcb76a4de4f514c6825c,
  author = {Pablo Gómez-Abajo and P. Cañizares and A. Núñez and E. Guerra and Juan de Lara},
  title = {Automated engineering of domain-specific metamorphic testing environments},
  journal = {Inf. Softw. Technol.},
  year = {2023},
  doi = {10.1016/j.infsof.2023.107164},
  volume = {157},
  pages = {107164}
}

@misc{77819686a67f932876f9ecb8b156d839fddf029b,
  author = {Paulo Eduardo Eduardo Silva dos Santos and J. Cal-Braz and Rodrigo Pereira David and Wilson de Souza Melo Jr.},
  title = {KLG-MT: a metamorphic testing framework for machine learning-based measuring systems},
  journal = {Measurement Science and Technology},
  year = {2026},
  doi = {10.1088/1361-6501/ae7625},
  volume = {37},
  abstract = {The increasing adoption of machine learning (ML) in software-controlled measuring systems introduces significant challenges for conformity assessment, particularly under black-box conditions where internal logic and correct outputs cannot be analytically determined. This limitation is closely related to the oracle problem, which restricts the applicability of conventional validation methods based solely on predictive accuracy metrics. To address this challenge, this paper proposes the knowledge-level–guided metamorphic testing (KLG-MT) method, a structured framework that organizes Metamorphic Testing according to progressive levels of operational knowledge available to the tester. The method enables behavioral evaluation of ML-based measuring systems by assessing sensitivity, causal coherence, and behavioral consistency under varying operational conditions without requiring access to internal model implementation. The applicability of the proposed method is demonstrated through a case study involving a real-world ML-based vehicular CO 2 emission soft sensor evaluated under strict black-box conditions. A total of 90 metamorphic test executions were conducted across three knowledge levels, revealing behavioral characteristics and structural limitations not identifiable through conventional accuracy-based validation alone. The results provide preliminary evidence that the KLG-MT method can serve as a practical complementary approach for the behavioral validation of ML-based measuring systems, particularly in regulatory and legal metrology contexts where transparency is limited and reliability requirements are critical.}
}

@misc{0773c981a9c8c0c7f9533dccc6fb97df4d739271,
  author = {Bo Zhang and Chi Zhang and Xiangyu Hu},
  title = {Automated regression test method for scientific computing libraries: Illustration with SPHinXsys},
  journal = {Journal of Hydrodynamics},
  year = {2024},
  doi = {10.1007/s42241-024-0042-6},
  volume = {36},

  title = {HOLISTIC CREDIBILITY ASSESSMENT OF A MACHINE LEARNING-BASED SURROGATE MODEL IN AN AERODYNAMICS APPLICATION},
  journal = {Unknown Journal},
  year = {2025},
  doi = {10.2172/3028632}
